{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": "worker.js",
  "name": "lazy-app",
  "compatibility_date": "2026-06-02",
  "routes": [
    {
      "pattern": "www.lazyapp.fr",
      "custom_domain": true
    },
    {
      "pattern": "lazyapp.fr",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
